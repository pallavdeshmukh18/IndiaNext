{
  "manifest_version": 3,
  "name": "IndiaNext Threat Lens",
  "version": "1.0.0",
  "description": "Capture current page screenshot and get an instant threat score.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Threat Lens"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ]
}
