{
  "manifest_version": 3,
  "name": "IndiaNext Threat Lens",
  "version": "1.1.0",
  "description": "Read the current screen and score how phishing-like the content looks.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Threat Lens"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
