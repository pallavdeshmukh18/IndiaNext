{
  "manifest_version": 3,
  "name": "IndiaNext Threat Lens",
  "version": "1.1.0",
  "description": "Read the current screen and score how phishing-like the content looks.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Threat Lens"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "utils/domExtractor.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
