PORT=8000
MONGO_URI=mongodb://127.0.0.1:27017/indianext
JWT_SECRET=replace_with_strong_secret

# Inference mode: local | api | auto
HF_INFERENCE_MODE=local
PYTHON_BIN=python

# Optional: only needed when HF_INFERENCE_MODE=api or auto-with-hosted-API
# HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides
# HF_API_BASE_URL=https://api-inference.huggingface.co/models
# HF_TIMEOUT_MS=30000
HF_MODEL_PHISHING_MESSAGING=aamoshdahal/email-phishing-distilbert-finetuned
HF_MODEL_MALICIOUS_URL=r3ddkahili/final-complete-malicious-url-model
HF_MODEL_DEEPFAKE_IMAGE=prithivMLmods/Deep-Fake-Detector-v2-Model
HF_MODEL_DEEPFAKE_AUDIO=mo-thecreator/Deepfake-audio-detection
HF_MODEL_PROMPT_INJECTION=protectai/deberta-v3-base-prompt-injection
HF_MODEL_ANOMALY_LOGS=ehsanaghaei/SecureBERT
HF_MODEL_AI_GENERATED_TEXT=openai-community/roberta-base-openai-detector
