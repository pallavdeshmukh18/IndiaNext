PORT=8000
MONGO_URI=mongodb://127.0.0.1:27017/indianext
JWT_SECRET=replace_with_strong_secret

# Inference mode: api | local | auto
HF_INFERENCE_MODE=api
PYTHON_BIN=python

# Optional: needed for higher limits/stability when HF_INFERENCE_MODE=api
# HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides
# HF_API_BASE_URL=https://router.huggingface.co/hf-inference/models
# HF_TIMEOUT_MS=60000
# HF_API_RETRIES=2
# HF_RETRY_DELAY_MS=2500
HF_MODEL_PHISHING_MESSAGING=facebook/bart-large-mnli
HF_MODEL_MALICIOUS_URL=facebook/bart-large-mnli
HF_MODEL_DEEPFAKE_IMAGE=prithivMLmods/Deep-Fake-Detector-v2-Model
HF_MODEL_DEEPFAKE_AUDIO=openai/whisper-large-v3
HF_MODEL_PROMPT_INJECTION=protectai/deberta-v3-base-prompt-injection
HF_MODEL_ANOMALY_LOGS=facebook/bart-large-mnli
HF_MODEL_AI_GENERATED_TEXT=openai-community/roberta-base-openai-detector
HF_MODEL_SCREEN_OCR=microsoft/trocr-base-printed

# Optional Twilio WhatsApp interactive messaging
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CONTENT_SID_MAIN_MENU=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CONTENT_SID_INPUT_MENU=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CONTENT_SID_RESCAN_MENU=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
